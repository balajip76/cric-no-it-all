# Supabase (backend)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection for asyncpg (Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.xxxx.supabase.co:5432/postgres

# Claude
ANTHROPIC_API_KEY=sk-ant-...

# Next.js public vars (prefix NEXT_PUBLIC_ for browser exposure)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=http://localhost:8000
